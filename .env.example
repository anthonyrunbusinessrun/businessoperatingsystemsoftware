# ─────────────────────────────────────────────
# BOSS Platform — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── RAILWAY ───────────────────────────────────
RAILWAY_TOKEN=your-railway-token
PORT=3000
NODE_ENV=development

# ── AIRTABLE (migration source — rotate after migration) ──
AIRTABLE_PAT=your-airtable-pat-here
AIRTABLE_BOSS_BASE_ID=app8QxH2cjt0fueuW
AIRTABLE_MELONBOOK_BASE_ID=appd4s8CSm5hjGQLd

# ── TELNYX SMS ────────────────────────────────
TELNYX_API_KEY=your-telnyx-api-key
TELNYX_MESSAGING_PROFILE_ID=400196e8-bae5-4159-bebc-d2f7d336abcf
TELNYX_FROM_NUMBER=+1xxxxxxxxxx

# ── EAS (Expo Application Services) ──────────
EXPO_TOKEN=your-expo-token

# ── POSTHOG ───────────────────────────────────
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# ── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
